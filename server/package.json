{
  "name": "normalite-edge-server",
  "version": "1.0.0",
  "description": "Normalite EDGE API Server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "@types/pdfkit": "0.17.5",
    "bcryptjs": "2.4.3",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "16.6.1",
    "express": "4.22.2",
    "express-rate-limit": "7.4.1",
    "google-auth-library": "10.9.0",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.3",
    "pdfkit": "0.17.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "22.19.15",
    "prisma": "6.19.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
