# Environment
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/normalite_edge
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/normalite_edge
PRISMA_CONNECTION_LIMIT=5
PRISMA_POOL_TIMEOUT=20

# Production (Supabase + Prisma + Render)
# DATABASE_URL should use the Supabase Session mode pooler with explicit Prisma pool limits.
# Example:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[PROJECT-REF].pooler.supabase.com:5432/postgres?sslmode=require
# DIRECT_URL should use the direct database host (for migrations / Prisma engine operations).
# Example:
# DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
# Prisma runtime pool settings can be controlled separately per environment.
# Recommended production defaults for Supabase Session mode on Render:
# PRISMA_CONNECTION_LIMIT=1
# PRISMA_POOL_TIMEOUT=30

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
