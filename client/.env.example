# Environment Configuration - Frontend (Normalite EDGE)
# Copy this file to .env.local for local development

# API Configuration
# Local development
VITE_API_URL=http://localhost:5000/api/v1

# For production, set VITE_API_URL to your Render backend URL
# Example: VITE_API_URL=https://normalite-edge-api.onrender.com/api/v1
